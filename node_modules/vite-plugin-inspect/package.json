{
  "name": "vite-plugin-inspect",
  "type": "module",
  "version": "12.0.2",
  "description": "Inspect the intermediate state of Vite plugins",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu-collective/vite-plugin-inspect#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu-collective/vite-plugin-inspect.git"
  },
  "bugs": {
    "url": "https://github.com/antfu-collective/vite-plugin-inspect/issues"
  },
  "keywords": [
    "vite-plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./nuxt": "./dist/nuxt.mjs",
    "./*": "./*",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=14"
  },
  "peerDependencies": {
    "vite": "^8.0.0-0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "dependencies": {
    "@vitejs/devtools-kit": "^0.4.0",
    "ansis": "^4.3.1",
    "error-stack-parser-es": "^2.0.1",
    "obug": "^2.1.3",
    "ohash": "^2.0.11",
    "open": "^11.0.0",
    "perfect-debounce": "^2.1.0",
    "sirv": "^3.0.2",
    "unplugin-utils": "^0.3.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@antfu/ni": "^30.2.0",
    "@antfu/utils": "^9.3.0",
    "@iconify/json": "^2.2.498",
    "@nuxt/kit": "^4.4.8",
    "@playwright/test": "^1.61.1",
    "@types/codemirror": "^5.60.17",
    "@types/node": "^25.9.5",
    "@unocss/eslint-config": "^66.7.5",
    "@unocss/eslint-plugin": "^66.7.5",
    "@unocss/reset": "^66.7.5",
    "@vitejs/devtools": "^0.4.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.39",
    "@vueuse/core": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "bumpp": "^11.1.0",
    "codemirror": "^5.65.16",
    "codemirror-theme-vars": "^0.1.2",
    "comlink": "^4.4.2",
    "diff-match-patch-es": "^1.0.1",
    "echarts": "^6.1.0",
    "eslint": "^10.7.0",
    "floating-vue": "^5.2.2",
    "fuse.js": "^7.4.2",
    "nano-staged": "^1.0.2",
    "pathe": "^2.0.3",
    "pinia": "^3.0.4",
    "premove": "^4.0.0",
    "publint": "^0.3.21",
    "simple-git-hooks": "^2.13.1",
    "skills-npm": "^1.2.0",
    "splitpanes": "^4.1.2",
    "tsdown": "^0.22.5",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vis-data": "^8.0.4",
    "vis-network": "^10.1.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue": "^3.5.39",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.7"
  },
  "resolutions": {
    "@vitejs/devtools": "catalog:dev",
    "@vitejs/devtools-kit": "catalog:prod",
    "vite": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*.{js,ts,vue,md}": "eslint --cache --fix"
  },
  "scripts": {
    "build": "premove dist && pnpm run --sequential /^build:/",
    "build:client": "vite build src/client",
    "build:js": "tsdown",
    "dev": "pnpm build:client && INSPECT_DEV=true vite src/client",
    "dev:client": "vite build src/client --watch",
    "watch": "tsdown --watch",
    "lint": "eslint .",
    "play": "pnpm -C playground run dev",
    "play:build": "pnpm -C playground run build",
    "test:e2e": "playwright test",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp"
  }
}